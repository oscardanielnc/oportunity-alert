# OportunityAlert — Variables de entorno
# Copiar este archivo como .env y completar los valores
# En la VM: cp .env.template .env && nano .env

# ── MOTOR DE IA (DeepSeek, dos tiers) ─────────────────────────────────────
# Sistema migrado a DeepSeek (2026-06-19). Compatible con OpenAI vía REST.
# Obtener key en: platform.deepseek.com → API Keys (regala 5M tokens al registrarte)
AI_ENGINE=deepseek                 # deepseek (default) | glm | gemini | claude
DEEPSEEK_API_KEY=sk-...            # OBLIGATORIA si AI_ENGINE=deepseek
# Modelos por tier (opcional — si se omiten usa los defaults de abajo):
AI_MODEL_STRONG=deepseek-v4-pro    # noticias / decisiones financieras (razonador)
AI_MODEL_CHEAP=deepseek-chat       # brief / Trump (no-pensante; deepseek-chat depreca 2026-07-24)
# Alternativa GLM (Z.ai): AI_ENGINE=glm + GLM_API_KEY=...

# ── OBLIGATORIAS ──────────────────────────────────────────────────────────

# Anthropic (Claude) — OPCIONAL: solo si AI_ENGINE=claude
# Obtener en: console.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-...

# Finnhub (noticias por ticker)
# Ya tienes credenciales en ~/trading/api_credentials.json
FINNHUB_API_KEY=tu_finnhub_key_aqui

# ── ALPACA (precio real-time AH/pre-market) ───────────────────────────────
# Crear cuenta GRATIS en alpaca.markets (no requiere depósito)
# Dashboard → API Keys → Paper Trading Keys
ALPACA_API_KEY=tu_alpaca_key_aqui
ALPACA_SECRET_KEY=tu_alpaca_secret_aqui

# ── TWILIO (envío de SMS) ─────────────────────────────────────────────────
# Obtener en: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_aqui

# ── REDDIT (opcional, para señales de hype) ───────────────────────────────
# Crear app en: reddit.com/prefs/apps → script
REDDIT_CLIENT_ID=tu_client_id
REDDIT_CLIENT_SECRET=tu_client_secret
REDDIT_USER_AGENT=OportunityAlert/1.0 by oscar_pairus
REDDIT_USERNAME=tu_usuario_reddit
REDDIT_PASSWORD=tu_password_reddit
